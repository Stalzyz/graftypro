#!/usr/bin/expect -f
set SERVER    "root@72.61.231.187"
set PASS      "Photoshop09@"
set REMOTE    "/root/grafty_bsp"
set timeout   60
puts "\n🔍 \[1/1\] Checking the host-level file to see if the fix even reached the VPS..."
spawn ssh -o StrictHostKeyChecking=no $SERVER "grep 'tracking-tight' $REMOTE/app/dashboard/templates/\\\[id\\\]/page.tsx"
expect {
    "password:" { send "$PASS\r"; exp_continue }
    eof
}
