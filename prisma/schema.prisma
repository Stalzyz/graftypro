model PaymentGatewayConfig {
  id            String   @id @default(uuid())
  provider      String   // razorpay, stripe, paypal
  key_id        String
  key_secret    String
  webhook_secret String?
  is_live       Boolean  @default(false)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("payment_gateway_configs")
}

model InvoiceSequence {
  id          String   @id @default(uuid())
  entity_id   String   @default("SYSTEM") // "SYSTEM" or Reseller ID
  year        Int
  next_number Int      @default(1)
  
  updated_at  DateTime @updatedAt
  
  @@unique([entity_id, year])
  @@map("invoice_sequences")
}

model Invoice {
  id              String   @id @default(uuid())
  invoice_number  String   @unique  // INV-2024-0001
  workspace_id    String
  wallet_id       String?
  reseller_id     String?
  
  // Financial Details
  net_amount      Decimal  // Amount before GST
  gst_amount      Decimal  // Total GST (18%)
  cgst_amount     Decimal  @default(0.00)  // Central GST (9%)
  sgst_amount     Decimal  @default(0.00)  // State GST (9%)
  igst_amount     Decimal  @default(0.00)  // Integrated GST (18%)
  total_amount    Decimal  // Amount after GST
  
  // GST Compliance Fields
  hsn_code        String   @default("998311") // Management consulting and IT services
  is_reverse_charge Boolean @default(false)
  place_of_supply String?  // State Name
  
  // Billing Details (Customer)
  billing_name    String
  billing_address String   @db.Text
  billing_gstin   String?  // Customer's GSTIN (optional)
  billing_state   String
  billing_pincode String
  billing_email   String?
  billing_phone   String?
  
  // Company Details (Grekam Academy)
  company_name    String   @default("Grekam Academy")
  company_gstin   String?
  company_address String?  @db.Text
  company_state   String?
  company_pincode String?
  
  // Security & Audit
  authorized_signature_url String?
  invoice_hash     String?   @unique // Immutable hash for audit
  
  // Payment Details
  payment_method  String   @default("Razorpay")
  payment_id      String?  // Razorpay payment_id
  payment_status  String   @default("PAID")  // PAID, PENDING, FAILED
  
  // Invoice Status
  status          String   @default("ACTIVE")  // ACTIVE, CANCELLED
  cancelled_reason String?
  cancelled_at    DateTime?
  
  // PDF Storage
  pdf_url         String?
  pdf_generated_at DateTime?
  
  // Email Status
  email_sent      Boolean  @default(false)
  email_sent_at   DateTime?
  
  // Metadata
  customer_type   String   @default("B2C") // B2B, B2C
  notes           String?  @db.Text
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  // Relations
  workspace       Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  wallet          VendorWallet? @relation("WalletInvoices", fields: [wallet_id], references: [id])
  transactions    CreditTransaction[] @relation("TransactionInvoice")
  reseller        Reseller? @relation(fields: [reseller_id], references: [id])
  items           InvoiceItem[]

  @@index([workspace_id])
  @@index([wallet_id])
  @@index([invoice_number])
  @@index([created_at])
  @@index([payment_status])
  @@map("invoices")
}

model FinanceConfig {
  id              String @id @default("global")
  last_locked_month Int? // 1-12
  last_locked_year  Int?
  
  invoice_header  String? @db.Text
  invoice_footer  String? @db.Text
  company_gstin   String?
  company_pan     String?
  bank_details    Json?   // { bank, account, ifsc, branch }
  upi_id          String?
  
  @@map("finance_config")
}

model InvoiceItem {
  id              String   @id @default(uuid())
  invoice_id      String
  
  description     String
  hsn_code        String?
  quantity        Decimal
  rate            Decimal
  taxable_value   Decimal
  
  // Tax breakdown per item
  cgst_rate       Decimal  @default(0.00)
  cgst_amount     Decimal  @default(0.00)
  sgst_rate       Decimal  @default(0.00)
  sgst_amount     Decimal  @default(0.00)
  igst_rate       Decimal  @default(0.00)
  igst_amount     Decimal  @default(0.00)
  
  total_amount    Decimal
  
  invoice         Invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  
  @@map("invoice_items")
}

// --------------------------------------
// ENTERPRISE CREDIT SYSTEM (Phases 1-9)
// --------------------------------------

model VendorWallet {
  id               String   @id @default(uuid())
  workspace_id     String   @unique
  
  // Balances
  current_balance  Decimal  @default(0.00)
  locked_balance   Decimal  @default(0.00)
  total_purchased  Decimal  @default(0.00)
  total_used       Decimal  @default(0.00)
  service_bonus_balance Decimal @default(0.00) // For Service-Only Referral Credits
  
  // Auto Top-up Settings
  auto_recharge_enabled   Boolean @default(false)
  auto_recharge_threshold Decimal @default(500.00)
  auto_recharge_amount    Decimal @default(1000.00)
  razorpay_customer_id    String? // For stored payment methods
  razorpay_token_id       String? // Stored card token for auto-charge
  
  // Fraud Detection Settings
  max_daily_velocity      Decimal @default(10000.00) // Max credits allowed per day
  velocity_alert_threshold Float  @default(2.0)      // Multiplier of avg usage to trigger alert
  is_automated_blocked    Boolean @default(false)    // System-level block if fraud detected
  
  // GST Details
  gst_registered   Boolean  @default(false)
  gstin            String?  @db.VarChar(15)  // GST Identification Number
  billing_name     String?
  billing_address  String?  @db.Text
  billing_state    String?
  billing_pincode  String?  @db.VarChar(6)
  billing_email    String?
  billing_phone    String?
  
  // Security & Fraud Protection
  is_frozen        Boolean  @default(false)
  freeze_reason    String?
  frozen_at        DateTime?
  frozen_by        String?  // Admin ID who froze the wallet
  
  // Metadata
  created_at       DateTime @default(now())
  updated_at       DateTime @default(now()) @updatedAt
  
  // Relations
  workspace        Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  ledger_entries   CreditTransaction[]
  invoices         Invoice[] @relation("WalletInvoices")

  @@index([workspace_id])
  @@map("vendor_wallets")
}

enum CreditTransactionType {
  PURCHASE
  DEDUCTION
  REFUND
  REVERSAL
  ADJUSTMENT
  REFERRAL_BONUS
}

model CreditTransaction {
  id               String                 @id @default(uuid())
  workspace_id     String
  wallet_id        String?  // Made optional for migration
  
  // Transaction Details
  type             CreditTransactionType
  amount           Decimal  // Can be negative for deductions
  
  // Balance Snapshots (Critical for audit)
  balance_before   Decimal
  balance_after    Decimal
  
  // GST Breakdown (for PURCHASE type)
  net_amount       Decimal  @default(0.00)  // Amount before GST
  gst_amount       Decimal  @default(0.00)  // Total GST
  cgst_amount      Decimal  @default(0.00)  // Central GST (9%)
  sgst_amount      Decimal  @default(0.00)  // State GST (9%)
  igst_amount      Decimal  @default(0.00)  // Integrated GST (18%)
  total_amount     Decimal  @default(0.00)  // Amount after GST
  
  // References (for idempotency)
  related_payment_id String?  @unique  // Razorpay payment_id
  related_message_id String?  @unique  // WhatsApp message_id
  meta_message_id    String?           // Meta's message ID
  invoice_id         String?
  
  // Message Details (for DEDUCTION type)
  message_category   String?  // MARKETING, UTILITY, AUTH, SERVICE
  country_code       String?
  meta_cost          Decimal  @default(0.00)  // What Meta charged us
  our_charge         Decimal  @default(0.00)  // What we charged vendor
  margin             Decimal  @default(0.00)  // Our profit
  
  // Fraud/Analytics
  velocity_score     Float?   // Calculated velocity at time of TX
  
  // Metadata
  description      String?
  initiated_by     String?  // User ID or SYSTEM
  ip_address       String?
  user_agent       String?
  
  // Status
  status           String   @default("COMPLETED")  // COMPLETED, FAILED, REVERSED
  failure_reason   String?
  
  // Timestamps
  created_at       DateTime @default(now())
  reversed_at      DateTime?
  
  // Relations
  wallet           VendorWallet? @relation(fields: [wallet_id], references: [id])
  invoice          Invoice?      @relation("TransactionInvoice", fields: [invoice_id], references: [id])

  @@index([workspace_id])
  @@index([workspace_id, created_at])
  @@index([wallet_id])
  @@index([type])
  @@index([created_at])
  @@index([related_payment_id])
  @@index([related_message_id])
  @@map("credit_transactions")
}

model CreditPricing {
  id               String   @id @default(uuid())
  message_type     String   // Marketing, Utility, Auth, Service
  country          String   // Country Name or ISO
  country_code     String?  // e.g. "91"
  
  meta_cost        Decimal
  platform_margin  Decimal
  reseller_margin  Decimal
  final_vendor_price Decimal

  @@unique([message_type, country])
  @@index([message_type, country_code])
  @@map("pricing_table")
}

model Feedback {
  id           String   @id @default(uuid())
  workspace_id String?
  reseller_id  String?
  name         String
  role         String   // VENDOR, RESELLER
  content      String
  rating       Int      @default(5)
