  max_flows        Int      @default(3)
  max_campaigns    Int      @default(1)
  max_messages     Int      @default(500)
  max_users        Int      @default(1)
  max_teams        Int      @default(0)
  
  // Module Access (Major Modules)
  module_quick_replies  Boolean @default(true)
  module_crm           Boolean @default(true)
  module_ecommerce     Boolean @default(false)
  module_academy       Boolean @default(false)
  module_drip          Boolean @default(false)
  module_integration   Boolean @default(false)
  
  // Flow Node Permissions (Bot Builder Control)
  flow_msg_access      Boolean @default(true)
  flow_automation_access Boolean @default(false)
  flow_logic_access     Boolean @default(false)
  flow_commerce_access  Boolean @default(false)
  flow_integration_access Boolean @default(false)

  // System Access Flags (Legacy Support)
  api_access          Boolean  @default(false)
  crm_access          Boolean  @default(true)   // Mapping to module_crm
  flow_builder_access  Boolean  @default(true)
  drip_campaign_access Boolean  @default(false)  // Mapping to module_drip
  commerce_access      Boolean  @default(false)  // Mapping to module_ecommerce
  edu_engine_access    Boolean  @default(false)  // Mapping to module_academy

  // UI/UX Metadata
  credits          Int      @default(0)
  features_list    Json?    @default("[]")
  bonus_text       String?   // Custom text for anything else (e.g. Everything in Growth, Mobile access)
  ai_fallback_enabled             Boolean @default(false)
  abandoned_cart_recovery_enabled Boolean @default(false)
  is_featured      Boolean  @default(false)
  badge_text       String?  @default("Most Popular") // Badge shown on card e.g. "Best Value"
  cta_label        String?  @default("Get Started")  // CTA button label
  accent_color     String?  @default("#27954D")      // Card accent color
  sort_order       Int      @default(0)              // Display order (lower = first)
  allowed_nodes    Json?    @default("[]")            // Deprecated: Moving to Boolean flags

  // Razorpay Plan IDs (auto-synced via Super Admin)
  razorpay_monthly_plan_id String?  // Stored after syncing to Razorpay
  razorpay_yearly_plan_id  String?  // Stored after syncing to Razorpay

  is_public        Boolean  @default(true)
  is_active        Boolean  @default(true)
  
  workspaces       Workspace[]
  
  reseller_id      String?
  reseller         Reseller? @relation("ResellerPlans", fields: [reseller_id], references: [id])
  
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("subscription_plans")
}

model VerificationOTP {
  id          String   @id @default(uuid())
  identifier  String   // email or phone
  code        String
  type        String   // 'EMAIL' | 'PHONE'
  expires_at  DateTime
  created_at  DateTime @default(now())

  @@unique([identifier, code])
  @@map("verification_otps")
}

// --------------------------------------
// GST & AUDIT SYSTEM
// --------------------------------------

model GSTReport {
  id                 String   @id @default(uuid())
  
  // Period
  month              Int      // 1-12
  year               Int      // 2024
  
  // Aggregated Amounts
  total_sales        Decimal  @default(0.00)  // Sum of all net amounts
  total_gst          Decimal  @default(0.00)  // Sum of all GST
  total_cgst         Decimal  @default(0.00)
  total_sgst         Decimal  @default(0.00)
  total_igst         Decimal  @default(0.00)
  
  // Statistics
  invoice_count      Int      @default(0)
  transaction_count  Int      @default(0)
  
  // Report Status
  status             String   @default("DRAFT")  // DRAFT, FINALIZED
  finalized_at       DateTime?
  
  // PDF Export
  pdf_url            String?
  
  // Metadata
  generated_at       DateTime @default(now())
  generated_by       String?  // Admin ID
  notes              String?  @db.Text
  
  @@unique([month, year])
  @@index([year, month])
  @@index([status])
  @@map("gst_reports")
}

model AuditLog {
  id                 String   @id @default(uuid())
  
  // Actor
  admin_id           String
  admin_email        String
  
  // Action
  action_type        String   // ADJUST_CREDITS, FREEZE_WALLET, REFUND, etc.
  target_type        String   // WALLET, TRANSACTION, INVOICE
  target_id          String
  target_workspace   String?
  
  // Changes
  before_value       Json?
  after_value        Json?
  
  // Reason & Context
  reason             String   @db.Text
  ip_address         String?
  user_agent         String?
  
  // Metadata
  created_at         DateTime @default(now())
  
  @@index([admin_id])
  @@index([target_workspace])
  @@index([action_type])
  @@index([created_at])
  @@map("audit_logs")
}

// --------------------------------------
// SUPER ADMIN CRM (Proposals)
// --------------------------------------

model Proposal {
  id              String   @id @default(uuid())
  protocol_id     String   @unique // PROP-2024-001
  
  client_name     String
  client_email    String?
  client_company  String?
  
  amount          Decimal  @default(0.00)
  currency        String   @default("INR")
  
  status          String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED
  
  valid_until     DateTime?
  sent_at         DateTime?
  accepted_at     DateTime?
  
  items           Json     @default("[]") // [{ description, quantity, price, total }]
  notes           String?  @db.Text
  
  // Metadata
  created_by      String?  // Admin ID
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  
  @@index([status])
  @@index([client_company])
  @@map("proposals")
}

model ResellerMonthlyStats {
  id              String   @id @default(uuid())
  reseller_id     String
  month           Int      // 1-12
  year            Int
  
  total_revenue   Decimal  @default(0.00) // Gross revenue generated by vendors
  net_profit      Decimal  @default(0.00) // Partner's share
  bonus_earned    Decimal  @default(0.00)
  is_locked       Boolean  @default(false)
  processed_at    DateTime?
  
  reseller        Reseller @relation(fields: [reseller_id], references: [id])

  @@unique([reseller_id, month, year])
  @@index([reseller_id])
  @@map("reseller_monthly_stats")
}
model FollowUp {
  id           String   @id @default(uuid())
  workspace_id String
  contact_id   String
  user_id      String
  scheduled_at DateTime
  reminder_at  DateTime?
  status       String   @default("PENDING") // PENDING, COMPLETED, OVERDUE, SNOOZED
  notes        String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  contact      Contact   @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("follow_ups")
}

model InternalNote {
  id           String   @id @default(uuid())
  workspace_id String
  contact_id   String
  user_id      String
  content      String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  contact      Contact   @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("internal_notes")
}

// --------------------------------------
// Landing Page CMS Engine
// --------------------------------------

model LandingPage {
  id              String           @id @default(uuid())
  slug            String           @unique // home, reseller, partner, etc.
  title           String
  description     String?
  seo_config      Json?            @default("{\"title\":\"\",\"description\":\"\",\"keywords\":\"\",\"og_image\":\"\"}")
  status          String           @default("DRAFT") // DRAFT, PUBLISHED
  banner_config   Json?            @default("{\"text\":\"\",\"image\":\"\",\"link\":\"\",\"is_active\":false}")
  custom_css      String?          @db.Text
  published_data  Json?            // Stores the current live snapshot
  
  sections        LandingSection[]
  versions        LandingVersion[]
  
  created_at      DateTime         @default(now())
  updated_at      DateTime         @updatedAt

  @@map("landing_pages")
}

model LandingSection {
  id              String      @id @default(uuid())
  page_id         String
  type            String      // HERO, FEATURES, PRICING, FAQ, CUSTOM_HTML, etc.
  content         Json        // Modular content based on type
  style_config    Json?       @default("{}") // CSS/Style overrides
  order           Int         @default(0)
  is_active       Boolean     @default(true)
  
  page            LandingPage @relation(fields: [page_id], references: [id], onDelete: Cascade)

  @@index([page_id])
  @@map("landing_sections")
}

model LandingVersion {
  id              String      @id @default(uuid())
  page_id         String
  version_number  Int
  snapshot        Json        // Full JSON snapshot of the page at that time
  published_by    String?
  created_at      DateTime    @default(now())
  
  page            LandingPage @relation(fields: [page_id], references: [id], onDelete: Cascade)

  @@index([page_id])
  @@map("landing_versions")
}

// --------------------------------------
// ENTERPRISE UNIVERSAL CRM MODULE
// --------------------------------------

model UniversalCrmColumn {
  id           String    @id @default(uuid())
  workspace_id String
  name         String
  key          String    // Normalized key e.g., "property_type"
  type         String    // TEXT, NUMBER, PHONE, EMAIL, DROPDOWN, MULTISELECT, DATE, CURRENCY, BOOLEAN, URL, FILE, NOTES
  is_required  Boolean   @default(false)
  is_visible   Boolean   @default(true)
  options      Json?     // For dropdowns/multiselects
  default_val  String?
  order        Int       @default(0)
  
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, key])
  @@map("universal_crm_columns")
}

model UniversalCrmStage {
  id           String    @id @default(uuid())
  workspace_id String
  name         String
  color        String?   @default("#94a3b8")
  order        Int       @default(0)

  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  leads        UniversalCrmLead[]

  @@map("universal_crm_stages")
}

model UniversalCrmLead {
  id           String    @id @default(uuid())
  workspace_id String
  
  // Core Fixed Fields (for easy querying & indexing)
  name         String
  phone        String?   
  email        String?
  source       String?
  status       String    @default("NEW") // Legacy or high-level status
  deal_value   Decimal   @default(0.00)
  
  // Relational Fields
  stage_id     String?
  assigned_to  String?   // User ID
  
  // Dynamic Structure
  custom_data  Json      @default("{}") // All custom column data stored here
  
  // Quick Context Links
  contact_id   String?   // Link to WhatsApp contact

  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  stage        UniversalCrmStage? @relation(fields: [stage_id], references: [id], onDelete: SetNull)
  user         User?     @relation(fields: [assigned_to], references: [id], onDelete: SetNull)
  contact      Contact?  @relation(fields: [contact_id], references: [id], onDelete: SetNull)
  activities   UniversalCrmActivity[]

  @@index([workspace_id])
  @@index([stage_id])
  @@index([phone])
  @@index([email])
  @@map("universal_crm_leads")
}

model UniversalCrmActivity {
  id           String    @id @default(uuid())
  workspace_id String
  lead_id      String
  user_id      String?
  
  type         String    // NOTE, STAGE_CHANGE, EMAIL_SENT, WHATSAPP_MSG, DRIP_TRIGGERED, PIPELINE_UPDATE
  details      Json?     // Granular structured data about the event
  notes        String?   @db.Text
  
  created_at   DateTime  @default(now())

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  lead         UniversalCrmLead   @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  user         User?     @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([lead_id])
  @@map("universal_crm_activities")
}

model PartnerDomain {
  id              String   @id @default(uuid())
  reseller_id     String
  domain          String   @unique // e.g., "app.chatflow.ai"
  
  // Verification
  verification_token String?  // For DNS verification
  is_verified     Boolean  @default(false)
  verified_at     DateTime?
  
  // Settings
  is_active       Boolean  @default(true)
  ssl_enabled     Boolean  @default(false)
  
  // CNAME tracking
  target_host     String   @default("app.grafty.pro")
  
  reseller        Reseller @relation(fields: [reseller_id], references: [id], onDelete: Cascade)

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([reseller_id])
  @@index([domain])
  @@map("partner_domains")
}

// --------------------------------------
// Marketing & Tools Lead Capture
// --------------------------------------

model PublicToolLead {
  id         String   @id @default(uuid())
  phone      String
  tool_type  String   // e.g., 'LINK_GENERATOR', 'COST_CALCULATOR'
  metadata   Json?    // Optional extra info (e.g. message, currency)
  created_at DateTime @default(now())

  @@index([phone])
}
