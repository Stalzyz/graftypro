// This is your Prisma schema file - FORCED UPDATE 2026
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------
// Core Multi-Tenant SaaS Tables
// --------------------------------------

enum UserRole {
  OWNER
  ADMIN
  FINANCE
  AGENT
}

enum WorkspaceStatus {
  ACTIVE
  SUSPENDED
  DARMANT
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

model Workspace {
  id            String          @id @default(uuid())
  name          String
  business_name String?
  website       String?         // Added for Business Profile
  status        WorkspaceStatus @default(ACTIVE)
  timezone      String          @default("UTC")
  created_at    DateTime        @default(now())
  updated_at    DateTime        @updatedAt
  
  // SaaS Billing
  plan               Plan     @default(FREE) // Keep for backward compat for now
  current_plan_id    String?  // Link to SubscriptionPlan
  subscription_id    String?  // Razorpay Sub ID
  subscription_status String? // active, created, halted
  
  // Billing Metadata
  billing_address   String?  @db.Text
  billing_state     String?
  billing_city      String?
  billing_pincode   String?
  billing_gstin     String?
  billing_email     String?
  
  // Bank / Payment Details
  bank_name         String?
  account_number    String?
  ifsc_code         String?

  plan_details       SubscriptionPlan? @relation(fields: [current_plan_id], references: [id])

  // Settings stored as JSON for flexibility
  settings      Json?           @default("{}") 

  // API Integration (Webhooks & External Requests)
  api_key       String?         @unique
  webhook_url   String?

  // Relations
  users         User[]
  teams         Team[]
  waba          WhatsAppAccount?
  templates     Template[]
  contacts      Contact[]
  conversations Conversation[]
  auto_responders AutoResponder[]
  flows         Flow[]
  goals         Goal[]
  campaigns     Campaign[]
  products      Product[]
  orders        Order[]
  integrations  Integration[]
  appointments  Appointment[]
  slots         AppointmentSlot[]
  drips         DripSequence[]
  messages      Message[]
  segments      Segment[]
  follow_ups    FollowUp[]
  internal_notes InternalNote[]
  
  // CRM Engine
  crm_leads      UniversalCrmLead[]
  crm_columns    UniversalCrmColumn[]
  crm_stages     UniversalCrmStage[]
  crm_activities UniversalCrmActivity[]
  // Reseller Migration (Phase 2: Permanent Mapping)
  reseller_id   String?
  reseller      Reseller?  @relation(fields: [reseller_id], references: [id])
  
  // Referral System
  referral_code       String? @unique // short code for sharing
  referred_by_id      String?
  referral_bonus_awarded Boolean @default(false)
  referred_by         Workspace? @relation("WorkspaceReferrals", fields: [referred_by_id], references: [id])
  referrals           Workspace[] @relation("WorkspaceReferrals")

  coupon_id     String?
  used_coupon   ResellerCoupon? @relation(fields: [coupon_id], references: [id])

  // Finance
  transactions  Transaction[]
  invoices      Invoice[]
  wallet        VendorWallet?

  commerce_stores  CommerceStore[]
  edu_forms        EduForm[]
  edu_leads        EduLead[]
  feedbacks        Feedback[]

  // --- SALES CONVERSION SYSTEM (Profiling) ---
  industry          String?
  revenue_range     String?
  whatsapp_goal     String?
  message_volume    String?
  use_api_already   Boolean? @default(false)
  needs_assistance  Boolean? @default(false)
  trial_ends_at     DateTime? // For 7-day trial tracking

  @@map("workspaces")
}

model Lead {
  id                String   @id @default(uuid())
  name              String
  email             String?
  business_name     String?
  whatsapp_number   String
  revenue_range     String?
  goal              String?  // lead_gen, recovery, etc.
  ip_address        String?
  user_agent        String?
  source            String?  // utm source etc.
  created_at        DateTime @default(now())

  @@map("leads")
}

model TrialLock {
  id            String   @id @default(uuid())
  email         String   @unique
  first_used_at DateTime @default(now())
  trial_ends_at DateTime
  
  @@map("trial_locks")
}

// ... (existing models)


// --------------------------------------
// COMMERCE ENGINE (Ultimate WhatsApp Commerce)
// --------------------------------------

enum CommercePlatform {
  WOOCOMMERCE
  SHOPIFY
  NATIVE
}

model CommerceStore {
  id                    String           @id @default(uuid())
  workspace_id          String
  name                  String           @default("My Store")
  platform             CommercePlatform @default(NATIVE)
  status               String           @default("ACTIVE")
  
  // Integration Secrets (Encrypted)
  encrypted_credentials Json?            
  webhook_secret        String?          @unique 

  // Store Configuration
  currency              String           @default("INR")
  timezone              String           @default("Asia/Kolkata")
  
  // GST & Billing Configuration
  gst_enabled           Boolean          @default(false)
  gst_number            String?
  pan_number            String?
  business_address      String?          @db.Text
  business_state        String?
  
  // Shipping Configuration
  shipping_provider     String?          // SHIPROCKET, DELHIVERY
  shipping_config       Json?            // API keys for shipping

  // Features
  cod_enabled           Boolean          @default(true)
  cod_fixed_fee         Decimal          @default(0.00) @db.Decimal(10, 2)
  referral_enabled      Boolean          @default(false)

  last_sync_at         DateTime?
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt

  workspace            Workspace        @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  products             CommerceProduct[]
  orders               CommerceOrder[]
  coupons              CommerceCoupon[]
  categories           CommerceCategory[]
  referrals            CommerceReferral[]

  @@map("commerce_stores")
}

model CommerceCategory {
  id           String           @id @default(uuid())
  store_id     String
  name         String
  external_id  String?          // For sync
  
  store        CommerceStore    @relation(fields: [store_id], references: [id], onDelete: Cascade)
  products     CommerceProduct[]

  @@unique([store_id, external_id])
  @@map("commerce_categories")
}

model CommerceProduct {
  id            String             @id @default(uuid())
  store_id      String
  category_id   String?
  name          String
  description   String?            @db.Text
  price         Decimal            @db.Decimal(10, 2)
  compare_at_price Decimal?        @db.Decimal(10, 2)
  sku           String?
  stock         Int                @default(0)
  image_urls    String[]
  
  // Sync Meta
  external_id   String?            
  platform_url  String?            

  // GST Compliance
  hsn_code      String?
  gst_rate      Decimal            @default(18.00) @db.Decimal(10, 2)
  
  // Shipping
  weight_grams  Int                @default(0)
  is_cod_available Boolean         @default(true)

  is_active     Boolean            @default(true)
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt

  store         CommerceStore      @relation(fields: [store_id], references: [id], onDelete: Cascade)
  category      CommerceCategory?  @relation(fields: [category_id], references: [id])
  variants      CommerceProductVariant[]
  order_items   CommerceOrderItem[]

  @@unique([store_id, external_id])
  @@index([store_id])
  @@map("commerce_products")
}

model CommerceProductVariant {
  id            String             @id @default(uuid())
  product_id    String
  name          String             // e.g. "Red / XL"
  sku           String?
  price         Decimal            @db.Decimal(10, 2)
  stock         Int                @default(0)
  external_id   String?

  product       CommerceProduct    @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, external_id])
  @@map("commerce_product_variants")
}

model CommerceOrder {
  id                  String             @id @default(uuid())
  store_id            String
  contact_id          String
  
  external_id         String?            // External Order ID
  order_number        String             @unique // Our internal number
  
  status              String             @default("PLACED") // PLACED, PAID, SHIPPED, DELIVERED, CANCELLED, REFUNDED
  payment_status      String             @default("PENDING") // PENDING, PAID, FAILED, REFUNDED
  payment_method      String?            // RAZORPAY, STRIPE, COD, WALLET
  
  // Amount Details
  subtotal            Decimal            @db.Decimal(10, 2)
  tax_total           Decimal            @db.Decimal(10, 2)
  shipping_total      Decimal            @db.Decimal(10, 2)
  discount_total      Decimal            @db.Decimal(10, 2)
  total_amount        Decimal            @db.Decimal(10, 2)
  
  // GST Snapshot
  cgst                Decimal            @default(0.00) @db.Decimal(10, 2)
  sgst                Decimal            @default(0.00) @db.Decimal(10, 2)
  igst                Decimal            @default(0.00) @db.Decimal(10, 2)
  customer_gstin      String?

  // Shipping details
  shipping_address    Json?              // { name, address, city, state, pincode, phone }
  billing_address     Json?              
  tracking_id         String?
  courier_name        String?
  tracking_status     String?            // IN_TRANSIT, OUT_FOR_DELIVERY, DELIVERED, etc.
  tracking_last_check DateTime?

  // Referral / Rewards
  referral_id         String?
  
  metadata            Json?              @default("{}")
  
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt

  store               CommerceStore      @relation(fields: [store_id], references: [id], onDelete: Cascade)
  contact             Contact            @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  items               CommerceOrderItem[]
  referral            CommerceReferral?  @relation("OrderReferral", fields: [referral_id], references: [id])
  events              CommerceEvent[]

  @@unique([store_id, external_id])
  @@map("commerce_orders")
}

model CommerceOrderItem {
  id                  String             @id @default(uuid())
  order_id            String
  product_id          String?
  variant_id          String?
  
  name                String             // Snapshot name
  quantity            Int
  price               Decimal            @db.Decimal(10, 2)
  tax_rate            Decimal            @default(0.00) @db.Decimal(10, 2)
  tax_amount          Decimal            @default(0.00) @db.Decimal(10, 2)
  total               Decimal            @db.Decimal(10, 2)

  order               CommerceOrder      @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product             CommerceProduct?    @relation(fields: [product_id], references: [id])

  @@map("commerce_order_items")
}

model CommerceCoupon {
  id                  String             @id @default(uuid())
  store_id            String
  code                String             @unique
  description         String?
  
  discount_type       String             // PERCENTAGE, FLAT
  discount_value      Decimal            @db.Decimal(10, 2)
  
  min_order_value     Decimal?           @db.Decimal(10, 2)
  max_discount_amount Decimal?           @db.Decimal(10, 2)
  
  start_at            DateTime?
  end_at              DateTime?
  usage_limit         Int?
  usage_count         Int                @default(0)
  
  is_active           Boolean            @default(true)

  store               CommerceStore      @relation(fields: [store_id], references: [id], onDelete: Cascade)

  @@map("commerce_coupons")
}

model CommerceReferral {
  id                  String             @id @default(uuid())
  store_id            String
  referrer_contact_id String
  referee_contact_id  String             @unique
  
  referral_code       String
  reward_amount       Decimal            @default(0.00) @db.Decimal(10, 2)
  status              String             @default("PENDING") // PENDING, SUCCESS, FAILED
  
  store               CommerceStore      @relation(fields: [store_id], references: [id], onDelete: Cascade)
  orders              CommerceOrder[]    @relation("OrderReferral")

  @@map("commerce_referrals")
}

model CommerceEvent {
  id               String        @id @default(uuid())
  order_id         String
  event_type       String        // order.placed, order.paid, checkout.abandoned
  processed_status String        @default("PENDING")
  payload          Json?         // Original webhook data
  
  created_at       DateTime      @default(now())

  order            CommerceOrder @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("commerce_events")
}

// --------------------------------------
// EDUTECH CONVERSION ENGINE (Phased Build)
// --------------------------------------

enum EduLeadStatus {
  NEW
  CONTACTED
  FOLLOW_UP
  DEMO_SCHEDULED
  PAYMENT_PENDING
  ENROLLED
  LOST
}

model EduForm {
  id           String   @id @default(uuid())
  workspace_id String
  name         String   // e.g. "Summer Batch Inquiry"
  type         String   // INQUIRY, DEMO, SCHOLARSHIP
  fields       Json     // [{ name: "grade", type: "select", options: ["10th", "12th"] }]
  
  success_msg  String?
  redirect_url String?
  
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  leads        EduLead[]

  @@map("edu_forms")
}

model EduLead {
  id                String        @id @default(uuid())
  workspace_id      String
  form_id           String?
  
  student_name      String
  parent_name       String?
  whatsapp_number   String
  email             String?
  
  grade             String?
  course_interested String?
  budget_range      String?
  city              String?
  
  status            EduLeadStatus @default(NEW)
  counselor_id      String?
  
  notes             String?
  potential_revenue Decimal       @default(0)
  
  // Custom Attributes
  attributes        Json          @default("{}")
  
  // Tracking
  lead_source       String?       // WhatsApp Flow, QR, Landing Page, Ad
  follow_up_count   Int           @default(0)
  last_contacted_at DateTime?
  
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  workspace         Workspace     @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  form              EduForm?      @relation(fields: [form_id], references: [id])
  activities        EduLeadActivity[]

  @@index([workspace_id, status])
  @@map("edu_leads")
}

model EduLeadActivity {
  id           String   @id @default(uuid())
  lead_id      String
  type         String   // STATUS_CHANGE, NOTE_ADDED, MESSAGE_SENT, PAYMENT_LINK, DEMO_SCHEDULED
  content      String   // Description of activity
  old_status   String?
  new_status   String?
  created_at   DateTime @default(now())
  
  lead         EduLead  @relation(fields: [lead_id], references: [id], onDelete: Cascade)

  @@map("edu_lead_activities")
}

model Segment {
  id           String   @id @default(uuid())
  workspace_id String
  name         String
  description  String?
  
  // JSON rules: { "tags": ["VIP"], "min_orders": 5, "last_active_days": 7 }
  filters      Json     @default("{}")
  
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("segments")
}

model User {
  id             String    @id @default(uuid())
  workspace_id   String
  email          String
  password_hash  String?
  role           UserRole  @default(AGENT)
  first_name     String?
  last_name      String?
  phone          String?   // Added for OTP
  phone_verified DateTime? // OTP Verification Timestamp
  google_id      String?   // OAuth
  email_verified DateTime?
  welcome_offer_claimed Boolean @default(false)
  avatar_url     String?   // User Profile Picture
  bio            String?   @db.Text
  job_title      String?
  
  // --- Security Hardening ---
  failed_login_attempts Int      @default(0)
  locked_until         DateTime?
  last_login_at        DateTime?
  last_login_ip        String?
  two_factor_enabled   Boolean   @default(false)
  email_otp_verified   Boolean   @default(false)
  remember_token_hash  String?   // Hashed Token for Remember Me
  
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  workspace      Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  teams          TeamMember[]
  assigned_chats Conversation[] @relation("AgentConversations")
  auth_logs      AuthAuditLog[]
  remember_tokens RememberMeToken[]
  follow_ups     FollowUp[]
  internal_notes InternalNote[]
  crm_leads      UniversalCrmLead[]
  crm_activities UniversalCrmActivity[]

  @@unique([workspace_id, email]) // Email unique per workspace
  @@map("users")
}

model RememberMeToken {
  id           String   @id @default(uuid())
  user_id      String
  token_hash   String   @unique
  expires_at   DateTime
  created_at   DateTime @default(now())

  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("remember_me_tokens")
}

model AuthAuditLog {
  id            String   @id @default(uuid())
  user_id       String?
  email         String   // Track email even if user not found (for failed logins)
  action        String   // LOGIN_SUCCESS, LOGIN_FAILURE, GOOGLE_LOGIN, OTP_VERIFY, PASS_RESET, ACCOUNT_LOCK
  status        String   // SUCCESS, FAILURE
  ip_address    String?
  user_agent    String?
  details       Json?    // Any extra data like device info
  created_at    DateTime @default(now())

  user          User?    @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([email])
  @@index([created_at])
  @@map("auth_audit_logs")
}

model Team {
  id           String   @id @default(uuid())
  workspace_id String
  name         String
  description  String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace    Workspace    @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  members      TeamMember[]

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid())
  team_id   String
  user_id   String
  joined_at DateTime @default(now())

  team      Team     @relation(fields: [team_id], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([team_id, user_id])
  @@map("team_members")
}

// --------------------------------------
// WhatsApp Business Structure
// --------------------------------------

enum IntegrationStatus {
  DRAFT           // Credentials entered, not validated
  VALIDATING      // Validation in progress
  ACTIVE          // Fully operational
  DEGRADED        // Working but with warnings
  PAUSED          // Manually paused by user
  SUSPENDED       // Auto-paused due to risk
  DISABLED        // Permanently disabled
  FAILED          // Validation failed
}

enum HealthStatus {
  HEALTHY         // All checks passing
  WARNING         // Minor issues detected
  CRITICAL        // Major issues, auto-pause triggered
  UNKNOWN         // Not yet checked
}

enum BillingModel {
  MANAGED  // Platform Wallet (Meta Cost + Markup)
  DIRECT   // Self-managed token (Flat Orchestration Fee)
}

enum WabaStatus {
  CONNECTED
  DISCONNECTED
  BANNED
}

model WhatsAppAccount {
  id               String            @id @default(uuid())
  workspace_id     String            @unique // One WABA per workspace for this MVP
  
  // Enhanced Status Management
  integration_status IntegrationStatus @default(DRAFT)
  health_status      HealthStatus      @default(UNKNOWN)
  status             WabaStatus       @default(CONNECTED) // Legacy field
  billing_model      BillingModel     @default(MANAGED)
  
  // Custom Settings
  connection_name    String           @default("WhatsApp Channel")
  profile_picture_url String?
  
  // Meta Credentials (Enhanced)
  app_id             String?           // Meta App ID
  app_secret         String?           // Encrypted
  access_token       String            // Encrypted
  waba_id            String            // Meta WABA ID
  phone_number_id    String           @unique // Meta Phone Number ID
  phone_number       String
  display_name       String?
  business_id        String?           // Meta Business Manager ID
  
  // Webhook Configuration
  webhook_url        String?           // Generated webhook URL
  webhook_verify_token String?         // Generated verify token
  webhook_verified_at  DateTime?       // When webhook was verified
  
  // Permissions & Scopes
  granted_permissions Json?            // Array of granted permissions
  required_permissions Json?           // Array of required permissions
  permission_check_at  DateTime?       // Last permission check
  validated_at         DateTime?       // When credentials were last validated
  
  // Health Metrics & Status
  last_health_check_at DateTime?
  last_error           String?
  token_valid          Boolean @default(true)
  webhook_status       String  @default("OK")
  api_status           String  @default("OK")
  
  last_successful_send_at DateTime?
  consecutive_failures Int @default(0)
  
  // Risk Indicators
  quality_rating     String?           // GREEN, YELLOW, RED
  messaging_limit    String?           // 250, 1K, 10K, 100K, UNLIMITED
  rate_limit_tier    String?           // Tier information
  
  // Compliance Configuration
  opt_out_keywords     String?           @default("STOP,CANCEL,UNSUBSCRIBE")
  opt_out_message      String?           @default("Type STOP to unsubscribe from our messages.")
  opt_out_reply        String?           @default("You have been successfully unsubscribed. You will no longer receive messages from us.")
  
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt

  workspace        Workspace  @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  health_logs      IntegrationHealthLog[]
  audit_logs       IntegrationAuditLog[]

  @@map("whatsapp_accounts")
}

enum HealthCheckType {
  TOKEN_VALIDITY
  WEBHOOK_REACHABILITY
  PERMISSION_CHECK
  PHONE_STATUS
  RATE_LIMIT_CHECK
  MESSAGE_DELIVERY
  QUALITY_RATING
}

model IntegrationHealthLog {
  id                   String   @id @default(uuid())
  whatsapp_account_id  String
  
  check_type           HealthCheckType
  status               String   // PASS, WARN, FAIL
  
  details              Json     // Check-specific data
  error_message        String?
  
  checked_at           DateTime @default(now())
  
  whatsapp_account     WhatsAppAccount @relation(fields: [whatsapp_account_id], references: [id], onDelete: Cascade)
  
  @@index([whatsapp_account_id, checked_at])
  @@map("integration_health_logs")
}

enum AuditAction {
  INTEGRATION_CREATED
  CREDENTIALS_UPDATED
  VALIDATION_STARTED
  VALIDATION_PASSED
  VALIDATION_FAILED
  ACTIVATED
  PAUSED
  SUSPENDED
  RESUMED
  DELETED
  WEBHOOK_VERIFIED
  PERMISSION_GRANTED
  PERMISSION_REVOKED
  HEALTH_CHECK_FAILED
  AUTO_SUSPENDED
  WEBHOOK_ROUTING_FAILED
  
  // Reseller Actions
  RESELLER_REGISTERED
  RESELLER_APPROVED
  RESELLER_SUSPENDED
  RESELLER_MARGING_CHANGED
  VENDOR_MAPPED_TO_RESELLER
}

model IntegrationAuditLog {
  id                   String   @id @default(uuid())
  whatsapp_account_id  String?
  workspace_id         String
  user_id              String?
  
  action               AuditAction
  details              Json?
  ip_address           String?
  user_agent           String?
  
  created_at           DateTime @default(now())
  
  whatsapp_account     WhatsAppAccount? @relation(fields: [whatsapp_account_id], references: [id], onDelete: Cascade)
  
  @@index([whatsapp_account_id, created_at])
  @@index([workspace_id, created_at])
  @@map("integration_audit_logs")
}

enum TemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum TemplateStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  PAUSED
  DISABLED
  IN_APPEAL
  DELETED
  PENDING_DELETION
}

model Template {
  id           String         @id @default(uuid())
  workspace_id String
  waba_id      String?        // Optional link directly to WABA
  
  name         String
  language     String
  category     TemplateCategory
  status       TemplateStatus   @default(DRAFT)
  
  components   Json           // Header, Body, Footer, Buttons
  
  meta_id      String?         // ID from Meta
  
  variables    TemplateVariable[]
  drip_steps   DripStep[]

  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt

  workspace    Workspace      @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, name, language])
  @@map("templates")
}

model TemplateVariable {
  id           String   @id @default(uuid())
  template_id  String
  
  component_index Int    // 0 = Header, 1 = Body, etc. (Or strict type enum)
  param_index     Int    // {{1}} = 1
  sample_value    String 
  
  template     Template @relation(fields: [template_id], references: [id], onDelete: Cascade)

  @@map("template_variables")
}

// --------------------------------------
// Contact & Conversation Layer (Placeholder for Sub-Prompt 2)
// --------------------------------------

model Contact {
  id           String   @id @default(uuid())
  workspace_id String
  phone        String
  name         String?
  email        String?
  avatar_url   String?
  
  tags         String[] @default([])
  attributes   Json     @default("{}") // Custom key-value pairs
  
  opt_in       Boolean  @default(true)
  blocked      Boolean  @default(false)
  unsubscribed_at DateTime?
  
  last_active_at DateTime @default(now())
  
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  conversations Conversation[]
  flow_sessions FlowSession[]
  orders        Order[]
  appointments  Appointment[]
  drip_enrollments DripEnrollment[]
  messages         Message[]
  follow_ups       FollowUp[]
  commerce_orders CommerceOrder[]
  internal_notes   InternalNote[]
  crm_leads        UniversalCrmLead[]

  @@unique([workspace_id, phone])
  @@map("contacts")
}

model Conversation {
  id           String   @id @default(uuid())
  workspace_id String
  contact_id   String
  status       String   @default("OPEN") // OPEN, CLOSED, EXPIRED
  
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  contact      Contact   @relation(fields: [contact_id], references: [id], onDelete: Cascade)

  @@map("conversations")
  
  messages     Message[]
  assigned_to  String?  // User ID assigned to this chat
  agent        User?    @relation("AgentConversations", fields: [assigned_to], references: [id])
}

enum MessageType {
  TEXT
  IMAGE
  TEMPLATE
  INTERACTIVE
  AUDIO
  VIDEO
  DOCUMENT
  CONTACTS
  ORDER
  UNKNOWN
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model Message {
  id           String   @id @default(uuid())
  workspace_id String
  conversation_id String
  contact_id   String
  
  meta_id      String?  @unique // ID from WhatsApp
  type         MessageType
  direction    MessageDirection
  
  content      Json     // The body/text/media url: { body: "Hello" } or { link: "..." }
  status       String   @default("SENT") // PENDING, SENT, DELIVERED, READ, FAILED
  
  // --- PRODUCTION MEDIA METADATA ---
  media_url    String?  @db.Text
  mime_type    String?
  file_name    String?
  file_size    Int?
  caption      String?  @db.Text
  // ---------------------------------

  // --- Delivery Intelligence Enhancements ---
  error_code   String?  // Meta error code (e.g. 131026)
  error_message String? // Human-readable translated message
  
  template_id  String?  // If this message was a template
  template_name String? // For quick grouping in analytics
  
  conversation_category String? // MARKETING, UTILITY, AUTHENTICATION, SERVICE
  
  // Lifecycle timestamps
  sent_at      DateTime?
  delivered_at DateTime?
  read_at      DateTime?
  failed_at    DateTime?
  // -------------------------------------------
  
  created_at   DateTime @default(now())

  workspace    Workspace     @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  conversation Conversation  @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  contact      Contact       @relation(fields: [contact_id], references: [id], onDelete: Cascade)

  @@index([conversation_id])
  @@map("messages")
}

// --------------------------------------
// System / Events
// --------------------------------------

model WebhookEvent {
  id           String   @id @default(uuid())
  meta_event_id String? @unique
  waba_id      String?
  payload      Json
  processed    Boolean  @default(false)
  created_at   DateTime @default(now())

  @@map("webhook_events")
}

// --------------------------------------
// No-Code Flow Builder
// --------------------------------------

enum FlowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Flow {
  id           String     @id @default(uuid())
  workspace_id String
  name         String
  trigger_keyword String? 
  
  nodes        Json       
  edges        Json       
  
  status       FlowStatus @default(DRAFT)
  
  published_at DateTime?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  workspace    Workspace  @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  sessions     FlowSession[]
  goal         Goal?
  analytics    FlowAnalytics[]
  auto_responders AutoResponder[]
  campaigns    Campaign[]
  drip_steps   DripStep[]

  @@map("flows")
}

model FlowSession {
  id           String   @id @default(uuid())
  flow_id      String
  contact_id   String
  current_node_id String? 
  state        Json?    // Collected variables
  
  is_completed Boolean  @default(false)
  is_waiting   Boolean  @default(false)
  next_run_at  DateTime?
  
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  flow         Flow     @relation(fields: [flow_id], references: [id], onDelete: Cascade)
  contact      Contact  @relation(fields: [contact_id], references: [id], onDelete: Cascade)

  @@map("flow_sessions")
}

model FlowAnalytics {
  id             String   @id @default(uuid())
  flow_id        String
  node_id        String
  hits           Int      @default(0)
  
  last_hit_at    DateTime @default(now())

  flow           Flow     @relation(fields: [flow_id], references: [id], onDelete: Cascade)

  @@unique([flow_id, node_id])
  @@map("flow_analytics")
}

// --------------------------------------
// Goal-Based Engine
// --------------------------------------

enum GoalType {
  BOOK_APPOINTMENT
  COLLECT_PAYMENT
  SELL_PRODUCT
  GET_LEAD_INFO
  CUSTOM
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

model Goal {
  id           String     @id @default(uuid())
  workspace_id String
  name         String
  type         GoalType
  status       GoalStatus @default(ACTIVE)

  // Configuration
  config       Json       // e.g. { "product_id": "123", "price": 500 }
  
  // The invisible flow powering this goal
  flow_id      String?    @unique
  flow         Flow?      @relation(fields: [flow_id], references: [id])
  drips        DripSequence[]

  // Intelligence
  metrics      GoalMetric[]
  
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  workspace    Workspace  @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("goals")
}

model GoalMetric {
  id           String   @id @default(uuid())
  goal_id      String
  date         DateTime @default(now())
  
  started_count   Int    @default(0)
  completed_count Int    @default(0)
  dropped_off_count Int @default(0)
  revenue         Float  @default(0.0)
  
  goal         Goal     @relation(fields: [goal_id], references: [id], onDelete: Cascade)

  @@map("goal_metrics")
}

// --------------------------------------
// Broadcasts / Campaigns
// --------------------------------------

enum CampaignStatus {
  DRAFT
  SCHEDULED
  PROCESSING
  COMPLETED
  FAILED
}

model Campaign {
  id           String     @id @default(uuid())
  workspace_id String
  name         String
  
  template_id  String?
  template_name String?   // Cache name for display
  flow_id      String?
  flow         Flow?      @relation(fields: [flow_id], references: [id])
  
  // Segment Config
  filters      Json       // e.g. { "tags": ["VIP"], "joined_after": "2024-01-01" }
  
  scheduled_at DateTime?
  status       CampaignStatus @default(DRAFT)
  
  // Statistics
  stats        CampaignStats?
  
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt

  workspace    Workspace  @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("campaigns")
}

model CampaignStats {
  id           String   @id @default(uuid())
  campaign_id  String   @unique
  
  total        Int      @default(0)
  sent         Int      @default(0)
  delivered    Int      @default(0)
  read         Int      @default(0)
  failed       Int      @default(0)
  replied      Int      @default(0)
  
  campaign     Campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade)
  
  @@map("campaign_stats")
}

// --------------------------------------
// Conversational Commerce
// --------------------------------------

model Product {
  id           String   @id @default(uuid())
  workspace_id String
  
  name         String
  description  String?
  image_url    String?
  price        Float
  currency     String   @default("INR")
  
  sku          String?
  is_active    Boolean  @default(true)
  
  variants     ProductVariant[]
  order_items  OrderItem[]
  
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@map("products")
}

model ProductVariant {
  id           String   @id @default(uuid())
  product_id   String
  name         String   // e.g. "Size: L"
  price_adj    Float    @default(0) // price adjustment
  
  product      Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_variants")
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model Order {
  id           String   @id @default(uuid())
  workspace_id String
  contact_id   String
  
  total_amount Float
  currency     String   @default("INR")
  status       OrderStatus @default(PENDING)
  
  tracking_id         String?
  courier_name        String?
  tracking_status     String?
  tracking_last_check DateTime?
  
  items        OrderItem[]
  
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  contact      Contact   @relation(fields: [contact_id], references: [id], onDelete: Cascade)

  @@map("orders")
}

model OrderItem {
  id           String   @id @default(uuid())
  order_id     String
  product_id   String?
  quantity     Int
  unit_price   Float
  total_price  Float
  
  order        Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product      Product?  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("order_items")
}

// --------------------------------------
// Integrations & Secrets
// --------------------------------------

enum IntegrationType {
  RAZORPAY
  STRIPE
  SHOPIFY
  CALENDLY
  GOOGLE_CALENDAR
}

model Integration {
  id           String   @id @default(uuid())
  workspace_id String
  type         IntegrationType
  
  credentials  Json     // Encrypted keys: { key_id: "...", key_secret: "..." }
  is_active    Boolean  @default(true)
  
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)

  @@unique([workspace_id, type]) // One active integration per type
  @@map("integrations")
}

// --------------------------------------
// Appointment Booking
// --------------------------------------

model AppointmentSlot {
  id           String   @id @default(uuid())
  workspace_id String
  
  start_time   DateTime
  end_time     DateTime
  is_booked    Boolean  @default(false)
  
  created_at   DateTime @default(now())

  workspace    Workspace     @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  appointment  Appointment?

  @@map("appointment_slots")
}

model Appointment {
  id           String   @id @default(uuid())
  workspace_id String
  contact_id   String
  slot_id      String   @unique
  
  status       String   @default("CONFIRMED") // CANCELLED, COMPLETED
  notes        String?
  
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace    Workspace       @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  contact      Contact         @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  slot         AppointmentSlot @relation(fields: [slot_id], references: [id], onDelete: Cascade)

  @@map("appointments")
}

// --------------------------------------
// Smart Drip Automation
// --------------------------------------

enum DripStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

model DripSequence {
  id           String   @id @default(uuid())
  workspace_id String
  name         String
  description  String?
  
  goal_id      String?  // Linked Goal (Stop if achieved)
  
  // Intelligence Settings
  stop_on_reply      Boolean @default(true)
  stop_on_interaction Boolean @default(true)
  
  // Timing & Lifecycle
  // settings: { business_hours: true, timezone: "Asia/Kolkata", days: [1,2,3,4,5] }
  settings     Json?    @default("{}")
  
  status       DripStatus @default(ACTIVE)
  steps        DripStep[]
  
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  goal         Goal?     @relation(fields: [goal_id], references: [id])
  
  enrollments  DripEnrollment[]

  @@map("drip_sequences")
}

model DripStep {
  id           String   @id @default(uuid())
  drip_id      String
  
  step_order   Int      // 1, 2, 3
  delay_hours  Int      // Delay from previous step (or start)
  
  // Content Type (Either Flow OR Template)
  flow_id      String? 
  template_id  String?
  
  drip         DripSequence @relation(fields: [drip_id], references: [id], onDelete: Cascade)
  flow         Flow?        @relation(fields: [flow_id], references: [id])
  template     Template?    @relation(fields: [template_id], references: [id])

  analytics    DripStepAnalytics?

  @@map("drip_steps")
}

model DripStepAnalytics {
  id           String   @id @default(uuid())
  step_id      String   @unique
  
  sent_count      Int   @default(0)
  delivered_count Int   @default(0)
  read_count      Int   @default(0)
  clicked_count   Int   @default(0)
  
  step         DripStep @relation(fields: [step_id], references: [id], onDelete: Cascade)

  @@map("drip_step_analytics")
}

model DripEnrollment {
  id           String   @id @default(uuid())
  drip_id      String
  contact_id   String
  
  current_step Int      @default(0)
  next_run_at  DateTime
  
  is_stopped   Boolean  @default(false)
  stop_reason  String?  // GOAL_ACHIEVED, USER_REPLIED, MANUALLY_STOPPED
  
  // Carry data from trigger (e.g. { "cart_total": 5000 })
  metadata     Json?    @default("{}")

  drip         DripSequence @relation(fields: [drip_id], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contact_id], references: [id], onDelete: Cascade)

  @@map("drip_enrollments")
}
model AutoResponder {
  id           String   @id @default(uuid())
  workspace_id String
  keyword      String
  match_type   String   @default("EXACT") // EXACT, CONTAINS, STARTS_WITH
  reply_type   String   @default("TEXT") // TEXT, FLOW
  reply_text   String?
  flow_id      String?
  
  status       Boolean  @default(true)
  
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  workspace    Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  flow         Flow?     @relation(fields: [flow_id], references: [id])

  @@unique([workspace_id, keyword])
  @@map("auto_responders")
}

// --------------------------------------
// SUPER ADMIN SYSTEM (Phase 1)
// --------------------------------------

enum AdminRole {
  SUPER_ADMIN
  SALES
  FINANCE
  SUPPORT
  READ_ONLY
}

model AdminUser {
  id            String    @id @default(uuid())
  email         String    @unique
  password_hash String
  role          AdminRole @default(SUPER_ADMIN)
  name          String?
  avatar_url    String?
  bio           String?   @db.Text
  
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  audit_logs      AdminAuditLog[]
  assigned_leads  CRMLead[]       @relation("SalesAssigned")
  crm_activities  CRMActivity[]

  @@map("admin_users")
}

model CRMLead {
  id              String   @id @default(uuid())
  type            String   @default("VENDOR") // VENDOR, RESELLER, WHITE_LABEL
  stage           String   @default("LEAD_CAPTURED") // LEAD_CAPTURED, CONTACTED, DEMO_SCHEDULED, PROPOSAL_SENT, NEGOTIATION, WON, LOST
  name            String
  email           String
  phone           String?
  company_name    String?
  source          String?  // Website, Referral, Ads, etc.
  
  deal_value      Decimal  @default(0.00)
  probability     Int      @default(10) // 0-100
  expected_close  DateTime?
  
  assigned_to     String?  // AdminUser ID
  manager         AdminUser? @relation("SalesAssigned", fields: [assigned_to], references: [id])
  
  notes           String?  @db.Text
  metadata        Json?    @default("{}") // Additional flexible data
  
  activities      CRMActivity[]
  
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@map("crm_leads")
}

model CRMActivity {
  id          String   @id @default(uuid())
  lead_id     String
  admin_id    String?
  action      String   // CALL, EMAIL, DEMO, NOTE, STAGE_CHANGE, PROPOSAL_GENERATED
  description String?  @db.Text
  details     Json?    // { old_stage: "...", new_stage: "..." }
  
  created_at  DateTime @default(now())
  
  lead        CRMLead  @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  admin       AdminUser? @relation(fields: [admin_id], references: [id])

  @@map("crm_activities")
}

model SalesTarget {
  id              String   @id @default(uuid())
  year            Int
  month           Int
  type            String   // REVENUE, VENDORS, RESELLERS, WHITE_LABEL
  target_value    Decimal
  current_value   Decimal  @default(0.00)
  
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@unique([year, month, type])
  @@map("sales_targets")
}

model AdminAuditLog {
  id            String    @id @default(uuid())
  admin_id      String
  action        String    // e.g. "BAN_VENDOR", "VIEW_REVENUE", "IMPERSONATE"
  resource      String?   // Target ID (e.g. Workspace ID, User ID)
  details       Json?     // { "reason": "Fraud", "old_value": "PRO", "new_value": "ENTERPRISE" }
  ip_address    String?
  
  created_at    DateTime  @default(now())

  admin         AdminUser @relation(fields: [admin_id], references: [id])

  @@map("admin_audit_logs")
}


// --------------------------------------
// HYBRID RESELLER ENGINE (Phases 1-7)
// --------------------------------------

enum ResellerStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum KYCStatus {
  NONE
  SUBMITTED
  VERIFIED
  REJECTED
}

enum PartnerRole {
  AFFILIATE
  PLATFORM
}

enum HomePageType {
  DEFAULT
  EXTERNAL
  CUSTOM
}

model Reseller {
  id                String         @id @default(uuid())
  email             String         @unique
  password_hash     String?        // For portal access
  name              String
  business_name     String?
  avatar_url        String?
  bio               String?        @db.Text
  last_login        DateTime?
  referral_code     String         @unique // short code e.g. "GREK123"
  
  status            ResellerStatus @default(PENDING)
  role              PartnerRole    @default(AFFILIATE)
  email_verified    Boolean        @default(false)
  
  // KYC & Compliance
  kyc_status        KYCStatus      @default(NONE)
  kyc_type          String?        // 'PERSONAL' | 'BUSINESS'
  kyc_data          Json?          // { id_type, id_number, documents: [], business_reg_number }
  kyc_notes         String?
  kyc_submitted_at  DateTime?
  kyc_verified_at   DateTime?
  
  // Commission Logic (Phase 3)
  base_commission   Decimal        @default(20.00) // Percentage
  markup_enabled    Boolean        @default(true)
  
  // Wallet (Phase 5)
  wallet_balance    Decimal        @default(0.00)
  total_earned      Decimal        @default(0.00)
  
  // Branding (Phase 1: Custom Branding Module)
  brand_name        String?
  logo_url          String?
  favicon_url       String?
  primary_color     String?         @default("#0F172A") // Default Slate 900
  secondary_color   String?         @default("#3B82F6") // Default Blue 500
  custom_domain     String?         @unique // e.g. "dashboard.reseller.com"
  domain_verified   Boolean?        @default(false)
  theme_mode        String?         @default("LIGHT")

  is_frozen         Boolean        @default(false)
  freeze_reason     String?
  risk_score        Int            @default(0) // 0-100
  
  tier_id           String?
  tier              ResellerTier?  @relation(fields: [tier_id], references: [id])
  
  // Billing & Operations (Phase B: Automated Billing)
  low_credit_threshold   Decimal        @default(500.00)
  billing_address        String?
  gst_number             String?        // Indian tax compliance
  
  // Encrypted Bank Details
  bank_account_holder    String?        // Encrypted
  bank_account_number    String?        // Encrypted
  bank_ifsc              String?        // Encrypted
  bank_name              String?
  
  // RazorpayX (Automated Payouts)
  razorpayx_contact_id   String?
  razorpayx_fund_account_id String?
  
  invoice_config         Json?          // White-label invoice settings
  
  // White-label Infrastructure
  smtp_config            Json?          // { host, port, user, pass, from_name, from_email }
  domain_settings        Json?          // { domain, status, ssl_active, verified_at }
  branding_settings     Json?          // { logo_url, dark_logo_url, favicon_url, primary_color, secondary_color }
  payment_gateways      Json?          // [{ provider: "Razorpay", key_id: "...", key_secret: "...", is_live: false, is_active: true }]
  
  partner_domains       PartnerDomain[]
  
  // Sub-Reseller Support (Multi-Tier)
  parent_reseller_id    String?
  parent_reseller       Reseller?      @relation("SubResellers", fields: [parent_reseller_id], references: [id])
  sub_resellers         Reseller[]     @relation("SubResellers")
  
  // Auto-Onboarding
  onboarding_bonus       Decimal        @default(0.00)
  onboarding_bonus_paid  Boolean        @default(false)
  
  // God Mode Features (Best BSP)
  broadcast_banner       String?        // Announcement to vendors
  broadcast_link         String?        // Link for banner
  support_email          String?        // Custom reseller support email
  support_url            String?        // Custom help center URL
  support_whatsapp       String?        // Custom reseller support whatsapp
  markup_percentage      Decimal        @default(0.00) // Profit markup for messages

  // Home Page Settings (Tier 1-3)
  home_page_type         HomePageType   @default(DEFAULT)
  external_home_url      String?
  custom_home_html       String?        @db.Text
  
  // Relations
  vendors           Workspace[]    // Mapped vendors (Phase 2)
  vendor_mappings   ResellerVendorMap[]
  ledger_entries    ResellerLedger[]
  invoices          ResellerInvoice[]
  payout_requests   ResellerPayoutRequest[]
  risk_logs         ResellerRiskLog[]
  fraud_proofs      ResellerFraudProof[]
  feedbacks         Feedback[]
  custom_plans      SubscriptionPlan[] @relation("ResellerPlans")
  
  coupons           ResellerCoupon[]
  leads             ResellerLead[]
  offers            ResellerOffer[]
  proposals         ResellerProposal[]
  vendor_invoices   Invoice[]
  
  monthly_stats     ResellerMonthlyStats[]
  created_at        DateTime       @default(now())
  updated_at        DateTime       @updatedAt

  @@map("resellers")
}

model ResellerRiskLog {
  id              String   @id @default(uuid())
  reseller_id     String
  signal_type     String   // SELF_REFERRAL, RAPID_SIGNUP, etc
  risk_impact     Int
  details         Json?
  
  created_at      DateTime @default(now())
  
  reseller        Reseller @relation(fields: [reseller_id], references: [id])

  @@index([reseller_id])
  @@index([created_at])
  @@map("reseller_risk_logs")
}

model ResellerTier {
  id                String     @id @default(uuid())
  name              String     @unique // Starter, Growth, Empire
  min_vendors       Int        @default(0)
  commission_rate    Decimal    @default(20.00)
  
  // Tier Bonus System
  monthly_revenue_threshold Decimal @default(0.00)
  bonus_percentage          Decimal @default(0.00) // Applied on top of profit
  
  resellers         Reseller[]
  
  @@map("reseller_tiers")
}

model ResellerVendorMap {
  id              String   @id @default(uuid())
  reseller_id     String
  workspace_id    String   @unique
  
  mapped_at       DateTime @default(now())
  referral_source String?  // Code used
  
  // Permanent Lock (Phase 2)
  is_permanent    Boolean  @default(true)
  
  reseller        Reseller  @relation(fields: [reseller_id], references: [id])

  @@index([reseller_id])
  @@map("reseller_vendor_maps")
}

// --------------------------------------
// RESELLER FINANCIALS (Phase 5 & 6)
// --------------------------------------

enum LedgerEntryType {
  COMMISSION
  PAYOUT
  REFUND_REVERSAL
  ADJUSTMENT
  BASE_COST_SPLIT
  PROFIT_SHARE
  WALLET_MARGIN
  TIER_BONUS
  REVENUE_SHARE
  BONUS_PAYOUT
  SUBSCRIPTION_FEE  // W2R: Wholesale cost deducted when partner provisions a vendor
}

model ResellerLedger {
  id              String          @id @default(uuid())
  reseller_id     String
  workspace_id    String?         // Which vendor triggered this
  
  amount          Decimal
  type            LedgerEntryType
  description     String?
  
  // Audit Trail
  reference_id    String?         // Transaction ID or Payout ID
  balance_after   Decimal
  
  created_at      DateTime        @default(now())
  
  reseller        Reseller        @relation(fields: [reseller_id], references: [id])

  @@unique([reference_id, type])
  @@index([reseller_id])
  @@index([reference_id])
  @@index([created_at])
  @@map("reseller_ledger")
}

enum PayoutRequestStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

model ResellerPayoutRequest {
  id              String              @id @default(uuid())
  reseller_id     String
  amount          Decimal
  status          PayoutRequestStatus @default(PENDING)
  
  // Payment Details
  payment_method  String?             // RAZORPAY, BANK_TRANSFER, etc.
  payment_details Json?               // VPA or Bank details
  admin_notes     String?
  
  // Fraud Detection
  risk_score      Int                 @default(0)
  risk_flags      Json?               // [{ flag: "FREQUENT_PAYOUT", severity: "HIGH" }]
  
  // Execution Info
  gateway_payout_id String?           // Razorpay Payout ID
  processed_by      String?           // Admin User ID
  processed_at    DateTime?
  created_at      DateTime            @default(now())

  reseller        Reseller            @relation(fields: [reseller_id], references: [id])

  @@index([reseller_id])
  @@index([status])
  @@index([created_at])
  @@map("reseller_payout_requests")
}

model ResellerFraudProof {
  id              String   @id @default(uuid())
  reseller_id     String
  transaction_id  String   @unique // The vendor's transaction ID
  
  proof_url       String   // Screenshot URL
  status          String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  
  // Automated Checks
  risk_score      Int      @default(0) // 0-100
  checks_passed   Json     @default("[]") // Results of OCR, EXIF, etc.
  
  admin_notes     String?
  verified_at     DateTime?
  created_at      DateTime @default(now())

  reseller        Reseller @relation(fields: [reseller_id], references: [id])

  @@index([reseller_id])
  @@map("reseller_fraud_proofs")
}

model ResellerCoupon {
  id              String   @id @default(uuid())
  reseller_id     String
  code            String   @unique
  discount_type   String   // PERCENTAGE, FLAT
  discount_value  Decimal
  valid_until     DateTime?
  usage_limit     Int?     @default(100)
  usage_count     Int      @default(0)
  is_active       Boolean  @default(true)
  
  // Rules
  plan_restrictions Json?    // Array of plan IDs
  new_users_only    Boolean  @default(true)
  
  created_at      DateTime @default(now())
  reseller        Reseller @relation(fields: [reseller_id], references: [id])
  
  // Relations
  workspaces      Workspace[] // Workspaces that used this coupon
  
  @@map("reseller_coupons")
}

model ResellerLead {
  id              String   @id @default(uuid())
  reseller_id     String
  name            String
  email           String?
  phone           String?
  business_name   String?
  status          String   @default("NEW") // NEW, CONTACTED, PROPOSAL_SENT, CONVERTED
  notes           String?
  source          String?  // Website, Referral, etc.
  
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
  reseller        Reseller @relation(fields: [reseller_id], references: [id])
  
  @@map("reseller_leads")
}

model ResellerOffer {
  id              String   @id @default(uuid())
  reseller_id     String
  title           String
  description     String?
  offer_type      String   // BUNDLE, DISCOUNT, FREE_CREDITS
  plan_id         String?
  discount_code   String?
  valid_until     DateTime?
  share_link      String?  @unique
  
  created_at      DateTime @default(now())
  reseller        Reseller @relation(fields: [reseller_id], references: [id])
  
  @@map("reseller_offers")
}

model ResellerProposal {
  id              String   @id @default(uuid())
  reseller_id     String
  lead_id         String?  // Optional relation to lead
  title           String
  items           Json     // JSON array of plans/features/prices
  total_amount    Decimal
  status          String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED
  
  created_at      DateTime @default(now())
  reseller        Reseller @relation(fields: [reseller_id], references: [id])
  
  @@map("reseller_proposals")
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

model ResellerInvoice {
  id              String        @id @default(uuid())
  invoice_number  String        @unique // e.g. INV-2026-0001
  reseller_id     String
  
  amount_subtotal Decimal
  tax_amount      Decimal       @default(0.00)
  amount_total    Decimal
  
  status          InvoiceStatus @default(ISSUED)
  pdf_url         String?
  
  billing_details Json?         // Snapshot of reseller address at time of issue
  
  created_at      DateTime      @default(now())
  paid_at         DateTime?
  
  reseller        Reseller      @relation(fields: [reseller_id], references: [id])

  @@index([reseller_id])
  @@map("reseller_invoices")
}

// --------------------------------------
// FINANCE & BILLING SYSTEM (Phase 6)
// --------------------------------------

enum TransactionType {
  SUBSCRIPTION_CHARGE
  CREDIT_PURCHASE
  REFUND
  COMMISSION_PAYOUT
  USAGE_CHARGE
}

enum TransactionStatus {
  SUCCESS
  FAILED
  PENDING
}

model Transaction {
  id              String            @id @default(uuid())
  workspace_id    String?           // Nullable for system-level transactions
  partner_id      String?           // Nullable
  
  amount          Float
  currency        String            @default("INR")
  type            TransactionType
  status          TransactionStatus @default(PENDING)
  
  description     String?
  reference_id    String?           // Razorpay payment ID, etc.
  
  created_at      DateTime          @default(now())

  workspace       Workspace?        @relation(fields: [workspace_id], references: [id])

  @@map("transactions")
}

