#!/usr/bin/expect -f

set timeout 30
set host "72.61.231.187"
set password "Photoshop09@"

puts "\n🔍 Streaming the last 50 log lines from the web container..."
spawn ssh -o StrictHostKeyChecking=no root@$host \
    "docker logs --tail 50 \$(docker ps --filter name=web --format '{{.Names}}' | head -1)"
expect {
    "password:" { send "$password\r"; exp_continue }
    eof
}
