#!/usr/bin/expect -f
set SERVER    "root@72.61.231.187"
set PASS      "Photoshop09@"
set timeout   120
puts "\n🚀 \[1/1\] ReadING full Nginx configuration..."
spawn ssh -o StrictHostKeyChecking=no $SERVER "cat /etc/nginx/sites-enabled/*"
expect {
    "password:" { send "$PASS\r"; exp_continue }
    eof
}
