set PASS "Photoshop09@"
set timeout 10
spawn ssh -o StrictHostKeyChecking=no $SERVER "cd /root/grafty_bsp && docker compose -f docker-compose.prod.yml exec db psql -U postgres -d postgres -c \"SELECT id, status, created_at FROM campaigns ORDER BY created_at DESC LIMIT 5;\""
