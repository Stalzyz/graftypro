#!/usr/bin/expect -f
set SERVER    "root@72.61.231.187"
set PASS      "Photoshop09@"
set REMOTE    "/root/grafty_bsp"
set timeout   120
spawn ssh -o StrictHostKeyChecking=no $SERVER "cd $REMOTE && docker compose -f docker-compose.prod.yml logs --tail=500 web | grep -A 20 'Meta Template Submission'"
expect {
    "password:" { send "$PASS\r"; exp_continue }
    eof
}
